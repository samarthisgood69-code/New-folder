v = int(input("enter the number of rows"))
for i in range(1, 1+v):
    for j in range(v -i):
        print(" ", end ="" )
    for j in range(2*i-1): 
        print("*", end="")
    print()
for i in range(v -1,0,-1):
    for j in range(v -i):
        print(" ", end ="" ) 
    for j in range(2*i-1):     
        print("*", end="")
    print()